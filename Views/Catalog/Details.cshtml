@model PetAdoptionManagementSystem.Models.Domain.Pet
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 mb-4">
            @if (!string.IsNullOrEmpty(Model.PhotoPath))
            {
                <img src="@Model.PhotoPath" class="img-fluid rounded shadow" alt="@Model.Name">
            }
            else
            {
                <div class="bg-light rounded d-flex align-items-center justify-content-center shadow" style="height: 400px;">
                    <i class="bi bi-camera text-muted" style="font-size: 4rem;"></i>
                </div>
            }
        </div>
        <div class="col-md-6">
            <h1 class="mb-3">@Model.Name</h1>
            <div class="mb-3">
                @if (Model.Status == PetAdoptionManagementSystem.Models.Domain.PetStatus.Available)
                {
                    <span class="badge bg-success fs-6">Available</span>
                }
                else if (Model.Status == PetAdoptionManagementSystem.Models.Domain.PetStatus.UnderReview)
                {
                    <span class="badge bg-warning text-dark fs-6">Under Review</span>
                }
                else
                {
                    <span class="badge bg-secondary fs-6">Adopted</span>
                }
            </div>

            <div class="row mb-4">
                <div class="col-6">
                    <p><strong>Species:</strong> @Model.Species</p>
                    <p><strong>Breed:</strong> @Model.Breed</p>
                    <p><strong>Age:</strong> @Model.AgeYears years</p>
                </div>
                <div class="col-6">
                    <p><strong>Gender:</strong> @Model.Gender</p>
                    <p><strong>Health:</strong> @Model.HealthStatus</p>
                    <p><strong>Added:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                </div>
            </div>

            <h5>About @Model.Name</h5>
            <p class="lead">@Model.Description</p>
            
            <div class="mt-5">
                @if (Model.Status == PetAdoptionManagementSystem.Models.Domain.PetStatus.Available)
                {
                    <a asp-controller="Adoption" asp-action="Apply" asp-route-petId="@Model.Id" class="btn btn-primary btn-lg">Apply to Adopt</a>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg" disabled>Not Available</button>
                    <p class="text-muted mt-2">This pet is currently not available for adoption.</p>
                }
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg ms-2">Back to Catalog</a>
            </div>
        </div>
    </div>
</div>