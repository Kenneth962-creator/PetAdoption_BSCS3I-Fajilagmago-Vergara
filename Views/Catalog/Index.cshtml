@model IEnumerable<PetAdoptionManagementSystem.Models.Domain.Pet>
@{
    ViewData["Title"] = "Meet Our Pets";
}

<div class="text-center mb-5">
    <h1 class="display-4">Find Your Perfect Companion</h1>
    <p class="lead">Browse our available pets and give them a forever home.</p>
</div>

<div class="row mb-4">
    <div class="col-md-6 mx-auto">
        <form method="get" class="d-flex">
            <select name="species" class="form-select me-2">
                <option value="">All Species</option>
                <option value="Dog" selected="@(ViewBag.Species == "Dog")">Dogs</option>
                <option value="Cat" selected="@(ViewBag.Species == "Cat")">Cats</option>
                <option value="Bird" selected="@(ViewBag.Species == "Bird")">Birds</option>
                <option value="Other" selected="@(ViewBag.Species == "Other")">Other</option>
            </select>
            <button type="submit" class="btn btn-primary">Filter</button>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center">
            <p class="text-muted">No pets available at the moment. Check back soon!</p>
        </div>
    }
    
    @foreach (var pet in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(pet.PhotoPath))
                {
                    <img src="@pet.PhotoPath" class="card-img-top" alt="@pet.Name" style="height: 250px; object-fit: cover;">
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                        <i class="bi bi-camera text-muted" style="font-size: 3rem;"></i>
                    </div>
                }
                <div class="card-body text-center">
                    <h5 class="card-title">@pet.Name</h5>
                    <p class="card-text text-muted">@pet.Breed • @pet.AgeYears yrs</p>
                    <a asp-action="Details" asp-route-id="@pet.Id" class="btn btn-outline-primary">View Details</a>
                </div>
            </div>
        </div>
    }
</div>