@{
    ViewData["Title"] = "OTP Verification Required";
    var returnUrl = ViewData["ReturnUrl"] as string ?? Url.Action("Index", "Home");
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Action requires OTP verification</h4>
                </div>
                <div class="card-body">
                    <p class="lead">For security, this action requires you to complete one-time password (OTP) verification.</p>
                    <p>If you were recently asked to verify, please follow the instructions on the login page to send or enter your OTP code.</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-primary" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl">Go to OTP verification</a>
                        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Return Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>