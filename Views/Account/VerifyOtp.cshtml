@model PetAdoptionManagementSystem.Models.ViewModels.VerifyOtpViewModel
@{
    ViewData["Title"] = "Verify OTP";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">@ViewData["Title"]</h2>
        <div class="alert alert-info">
            An OTP has been sent to <strong>@Model.Email</strong>. Please enter the 6-digit code below to verify your identity.
        </div>
        <form asp-action="VerifyOtp" method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Purpose" />
            <input type="hidden" asp-for="RememberMe" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-4">
                <label asp-for="OtpCode" class="form-label"></label>
                <input asp-for="OtpCode" class="form-control" autocomplete="off" />
                <span asp-validation-for="OtpCode" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Verify</button>
        </form>
        @if (Model.Purpose == "TwoFactor")
        {
            <div class="mt-3 text-center">
                <p>Lost access to email? <a asp-action="UseRecoveryCode" asp-route-email="@Model.Email">Use a recovery code instead</a></p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}