@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold text-primary">Pet Adopt</h1>
    <p class="lead mb-4">Find your new best friend today. We connect loving homes with pets in need.</p>
    
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg px-4 shadow-sm">View Available Pets</a>
        @if (!User.Identity.IsAuthenticated)
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">Create an Account</a>
        }
    </div>
</div>

<div class="row mt-5 pt-5">
    <div class="col-md-4 text-center mb-4">
        <i class="bi bi-heart-fill text-danger" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Save a Life</h3>
        <p class="text-muted">When you adopt, you're giving a second chance to an animal in need, making room for us to save more.</p>
    </div>
    <div class="col-md-4 text-center mb-4">
        <i class="bi bi-house-door-fill text-success" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Find a Companion</h3>
        <p class="text-muted">Pets bring joy, love, and companionship into your home. Experience the unconditional love of an adopted pet.</p>
    </div>
    <div class="col-md-4 text-center mb-4">
        <i class="bi bi-shield-check text-primary" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Veterinary Checked</h3>
        <p class="text-muted">All our pets are health-checked, vaccinated, and ready to become a part of your family immediately.</p>
    </div>
</div>
