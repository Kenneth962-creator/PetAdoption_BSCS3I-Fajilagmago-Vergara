@model PetAdoptionManagementSystem.Models.Domain.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
    var applications = ViewBag.Applications as IEnumerable<PetAdoptionManagementSystem.Models.Domain.AdoptionApplication>;
}

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">My Details</h5>
            </div>
            <div class="card-body">
                <p><strong>Name:</strong> @Model.FullName</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Member Since:</strong> @Model.CreatedAt.ToString("MMM yyyy")</p>
                <p><strong>Address:</strong> @(Model.Address ?? "Not provided")</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">My Adoption Applications</h5>
            </div>
            <div class="card-body p-0">
                @if (applications == null || !applications.Any())
                {
                    <div class="p-4 text-center text-muted">
                        <p>You haven't submitted any adoption applications yet.</p>
                        <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary">View Available Pets</a>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var app in applications)
                        {
                            <div class="list-group-item p-3">
                                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0">Application for @app.Pet?.Name</h6>
                                    <small class="text-muted">Submitted: @app.SubmittedAt.ToString("MMM dd, yyyy")</small>
                                </div>
                                <p class="mb-1">
                                    <strong>Status:</strong> 
                                    @if(app.Status == PetAdoptionManagementSystem.Models.Domain.ApplicationStatus.Pending)
                                    {
                                        <span class="badge bg-info text-dark">Pending</span>
                                    }
                                    else if (app.Status == PetAdoptionManagementSystem.Models.Domain.ApplicationStatus.Approved)
                                    {
                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Rejected</span>
                                    }
                                </p>
                                @if (!string.IsNullOrEmpty(app.AdminRemarks))
                                {
                                    <div class="alert alert-light border mt-2 mb-0 p-2 text-sm">
                                        <strong>Admin Note:</strong> @app.AdminRemarks
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>