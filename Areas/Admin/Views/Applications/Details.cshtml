@model PetAdoptionManagementSystem.Models.ViewModels.ReviewApplicationViewModel
@{
    var app = ViewBag.Application as PetAdoptionManagementSystem.Models.Domain.AdoptionApplication;
    ViewData["Title"] = "Application Details - " + app?.Pet?.Name;
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Application for @app?.Pet?.Name</h4>
                <span class="badge bg-light text-dark">Submitted: @app?.SubmittedAt.ToString("g")</span>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6 border-end">
                        <h5>Applicant Information</h5>
                        <p class="mb-1"><strong>Name:</strong> @app?.Applicant?.FullName</p>
                        <p class="mb-1"><strong>Email:</strong> <a href="mailto:@app?.Applicant?.Email">@app?.Applicant?.Email</a></p>
                        <p class="mb-1"><strong>Phone:</strong> @(app?.Applicant?.PhoneNumber ?? "N/A")</p>
                        <p class="mb-1"><strong>Address:</strong> @app?.Applicant?.Address</p>
                    </div>
                    <div class="col-md-6">
                        <h5>Pet Information</h5>
                        <p class="mb-1"><strong>Name:</strong> @app?.Pet?.Name</p>
                        <p class="mb-1"><strong>Species:</strong> @app?.Pet?.Species</p>
                        <p class="mb-1"><strong>Age:</strong> @app?.Pet?.AgeYears yrs</p>
                    </div>
                </div>

                <h5>Application Answers</h5>
                <hr />
                <div class="mb-3">
                    <strong>Why do you want to adopt?</strong>
                    <div class="p-3 bg-light rounded mt-1">@app?.Reason</div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Living Situation:</strong> @app?.LivingSituation</p>
                        <p><strong>Employment Status:</strong> @app?.EmploymentStatus</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Has other pets?</strong> @(app?.HasOtherPets == true ? "Yes" : "No")</p>
                        <p><strong>Has children < 12?</strong> @(app?.HasChildren == true ? "Yes" : "No")</p>
                    </div>
                </div>
                <p><strong>Agreed to Terms?</strong> @(app?.AgreedToTerms == true ? "Yes" : "No")</p>

                <hr/>
                
                <h5 class="mt-4">Review Decision</h5>
                <form asp-action="Review" method="post">
                    <input type="hidden" asp-for="ApplicationId" />
                    
                    <div class="mb-3">
                        <label asp-for="NewStatus" class="form-label">Set Status</label>
                        <select asp-for="NewStatus" class="form-select" asp-items="Html.GetEnumSelectList<PetAdoptionManagementSystem.Models.Domain.ApplicationStatus>()"></select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="AdminRemarks" class="form-label">Admin Remarks (sent in email)</label>
                        <textarea asp-for="AdminRemarks" class="form-control" rows="3"></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">Save Decision & Notify</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Back to list</a>
                </form>
            </div>
        </div>
    </div>
</div>