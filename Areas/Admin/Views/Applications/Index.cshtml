@model IEnumerable<PetAdoptionManagementSystem.Models.Domain.AdoptionApplication>
@{
    ViewData["Title"] = "Manage Applications";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Manage Applications</h2>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Filter by Status</label>
                <select name="statusFilter" class="form-select" asp-items="Html.GetEnumSelectList<PetAdoptionManagementSystem.Models.Domain.ApplicationStatus>()">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100"><i class="bi bi-filter"></i> Apply filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Applicant Name</th>
                        <th>Pet Name</th>
                        <th>Date Submitted</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.Applicant?.FullName</td>
                            <td class="align-middle fw-bold">@item.Pet?.Name</td>
                            <td class="align-middle">@item.SubmittedAt.ToString("MMM dd, yyyy")</td>
                            <td class="align-middle">
                                @if(item.Status == PetAdoptionManagementSystem.Models.Domain.ApplicationStatus.Pending)
                                {
                                    <span class="badge bg-info text-dark">Pending</span>
                                }
                                else if (item.Status == PetAdoptionManagementSystem.Models.Domain.ApplicationStatus.Approved)
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                            </td>
                            <td class="align-middle text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Review</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-4 d-flex justify-content-center">
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&statusFilter=@ViewBag.StatusFilter">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>