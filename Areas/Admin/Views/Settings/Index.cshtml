@model IEnumerable<PetAdoptionManagementSystem.Models.Domain.SiteSetting>
@{
    ViewData["Title"] = "Site Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Site Settings</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Save" method="post">
            <div class="row">
                @foreach (var setting in Model)
                {
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">@setting.Key</label>
                        @if (setting.Key == "AboutUs")
                        {
                            <textarea name="settings[@setting.Key]" class="form-control" rows="4">@setting.Value</textarea>
                        }
                        else
                        {
                            <input type="text" name="settings[@setting.Key]" value="@setting.Value" class="form-control" />
                        }
                    </div>
                }
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Settings</button>
            </div>
        </form>
    </div>
</div>