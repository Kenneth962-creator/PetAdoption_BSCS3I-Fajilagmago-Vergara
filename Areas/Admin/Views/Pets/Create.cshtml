@model PetAdoptionManagementSystem.Models.ViewModels.PetFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Pet" : "Edit Pet";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">@ViewData["Title"]</h4>
            </div>
            <div class="card-body">
                <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" enctype="multipart/form-data" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ExistingPhotoPath" />
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label">Name *</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Species" class="form-label">Species *</label>
                            <select asp-for="Species" class="form-select">
                                <option value="Dog">Dog</option>
                                <option value="Cat">Cat</option>
                                <option value="Bird">Bird</option>
                                <option value="Rabbit">Rabbit</option>
                                <option value="Guinea Pig">Guinea Pig</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Species" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Breed" class="form-label">Breed</label>
                            <input asp-for="Breed" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AgeYears" class="form-label">Age (Years)</label>
                            <input asp-for="AgeYears" type="number" step="0.1" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Gender" class="form-label">Gender</label>
                            <select asp-for="Gender" class="form-select">
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Unknown">Unknown</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Photo Upload (Leave empty to keep existing)</label>
                        @if (!string.IsNullOrEmpty(Model.ExistingPhotoPath))
                        {
                            <div class="mb-2">
                                <img src="@Model.ExistingPhotoPath" width="100" class="img-thumbnail" />
                            </div>
                        }
                        <input asp-for="Photo" type="file" class="form-control" accept="image/*" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="HealthStatus" class="form-label">Health Status</label>
                            <input asp-for="HealthStatus" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AdoptionFee" class="form-label">Adoption Fee ($)</label>
                            <input asp-for="AdoptionFee" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsVaccinated" class="form-check-input" />
                                <label asp-for="IsVaccinated" class="form-check-label">Vaccinated</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label">Adoption Status</label>
                        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<PetAdoptionManagementSystem.Models.Domain.PetStatus>()"></select>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Pet</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}