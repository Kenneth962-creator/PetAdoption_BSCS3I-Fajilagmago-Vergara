@model IEnumerable<PetAdoptionManagementSystem.Models.Domain.Pet>
@{
    ViewData["Title"] = "Manage Pets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Manage Pets</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add New Pet</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Search by name or species...">
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="statusFilter" class="form-select" asp-items="Html.GetEnumSelectList<PetAdoptionManagementSystem.Models.Domain.PetStatus>()">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100"><i class="bi bi-search"></i> Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Photo</th>
                    <th>Name</th>
                    <th>Species / Breed</th>
                    <th>Age</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.PhotoPath))
                            {
                                <img src="@item.PhotoPath" alt="@item.Name" width="40" height="40" class="rounded-circle object-fit-cover" />
                            }
                            else
                            {
                                <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 40px; height: 40px;"><i class="bi bi-camera"></i></div>
                            }
                        </td>
                        <td class="align-middle fw-bold">@item.Name</td>
                        <td class="align-middle">@item.Species <br><small class="text-muted">@item.Breed</small></td>
                        <td class="align-middle">@item.AgeYears yrs</td>
                        <td class="align-middle">
                            @if(item.Status == PetAdoptionManagementSystem.Models.Domain.PetStatus.Available)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else if(item.Status == PetAdoptionManagementSystem.Models.Domain.PetStatus.UnderReview)
                            {
                                <span class="badge bg-warning text-dark">Under Review</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Adopted</span>
                            }
                        </td>
                        <td class="align-middle text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this pet?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4 d-flex justify-content-center">
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&searchString=@ViewBag.SearchString&statusFilter=@ViewBag.StatusFilter">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>