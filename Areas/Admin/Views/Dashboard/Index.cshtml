@model PetAdoptionManagementSystem.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard Overview</h2>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Pets</h5>
                <h2 class="card-text">@Model.TotalPets</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Available</h5>
                <h2 class="card-text">@Model.AvailablePets</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-dark bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Pending Apps</h5>
                <h2 class="card-text">@Model.PendingApplications</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-secondary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Members</h5>
                <h2 class="card-text">@Model.TotalMembers</h2>
            </div>
        </div>
    </div>
</div>

<div class="row align-items-center mb-5">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Pets by Species</h5>
                <canvas id="speciesChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Applications by Status</h5>
                <canvas id="appsChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Recent Applications</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Applicant</th>
                        <th>Pet</th>
                        <th>Date Submitted</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.RecentApplications)
                    {
                        <tr>
                            <td>@app.Applicant?.FullName</td>
                            <td>@app.Pet?.Name</td>
                            <td>@app.SubmittedAt.ToString("g")</td>
                            <td>
                                @if(app.Status == PetAdoptionManagementSystem.Models.Domain.ApplicationStatus.Pending)
                                {
                                    <span class="badge bg-info text-dark">Pending</span>
                                }
                                else if (app.Status == PetAdoptionManagementSystem.Models.Domain.ApplicationStatus.Approved)
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Applications" asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-primary">Review</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.RecentApplications.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No recent applications.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const speciesCtx = document.getElementById('speciesChart');
        const appsCtx = document.getElementById('appsChart');

        const speciesKeys = @Html.Raw(Json.Serialize(Model.PetsBySpecies.Keys));
        const speciesValues = @Html.Raw(Json.Serialize(Model.PetsBySpecies.Values));

        const appKeys = @Html.Raw(Json.Serialize(Model.ApplicationsByStatus.Keys));
        const appValues = @Html.Raw(Json.Serialize(Model.ApplicationsByStatus.Values));

        new Chart(speciesCtx, {
            type: 'bar',
            data: {
                labels: speciesKeys,
                datasets: [{
                    label: '# of Pets',
                    data: speciesValues,
                    backgroundColor: '#1D9E75'
                }]
            }
        });

        new Chart(appsCtx, {
            type: 'doughnut',
            data: {
                labels: appKeys,
                datasets: [{
                    data: appValues,
                    backgroundColor: ['#0dcaf0', '#198754', '#dc3545']
                }]
            }
        });
    </script>
}