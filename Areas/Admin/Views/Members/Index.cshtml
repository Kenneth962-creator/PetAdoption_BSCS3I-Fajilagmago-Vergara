@model IEnumerable<PetAdoptionManagementSystem.Models.Domain.ApplicationUser>
@{
    ViewData["Title"] = "Members";
}

<h2 class="mb-4">Members</h2>

<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Registered</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                <td>
                    <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                        @(user.IsActive ? "Active" : "Inactive")
                    </span>
                </td>
                <td>
                    <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                            @(user.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>